# Global settings
max-history=100
sort=-time

# Appearance
font=monospace 10
width=300
height=100
margin=10
padding=10
border-size=2
border-radius=5

# Colors (Hex with alpha, e.g., #RRGGBBAA)
background-color=#1e1e2e
text-color=#cdd6f4
border-color=#89b4fa

default-timeout=5000

[urgency=high]
border-color=#ff0000ff
default-timeout=0

[urgency=low]
border-color=#a6e3a1
default-timeout=5000
